# Copy to .env and adjust for your environment.

POSTGRES_DB=mall
POSTGRES_USER=mall
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

ADMIN_PORT=8080
PORTAL_PORT=8085

SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xmx320m -Xms160m -XX:MaxMetaspaceSize=128m -XX:+UseG1GC

MALL_DOMAIN=http://localhost:8085
MALL_ADMIN_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8060
MALL_UPLOAD_PATH=/data/uploads
MALL_UPLOAD_URL=/uploads

SPRING_MAIL_FROM=mall@example.com
SES_SMTP_HOST=
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=

GLOBEPAY_PARTNER_CODE=
GLOBEPAY_CREDENTIAL_CODE=
GLOBEPAY_NOTIFY_URL=http://localhost:8085/portal/payment/h5/notify/globepay
GLOBEPAY_REDIRECT_URL=http://localhost:8060/payment/success
GLOBEPAY_CREDIT_CARD_RETURN_URL=http://localhost:8060/payment/success
GLOBEPAY_DEFAULT_CURRENCY=JPY
