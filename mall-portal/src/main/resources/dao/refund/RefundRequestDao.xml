<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.macro.mall.portal.dao.refund.RefundRequestDao">
    
    <resultMap id="BaseResultMap" type="com.macro.mall.common.domain.refund.RefundRequest">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="refund_sn" property="refundSn" jdbcType="VARCHAR"/>
        <result column="order_id" property="orderId" jdbcType="BIGINT"/>
        <result column="order_sn" property="orderSn" jdbcType="VARCHAR"/>
        <result column="payment_record_id" property="paymentRecordId" jdbcType="BIGINT"/>
        <result column="member_id" property="memberId" jdbcType="BIGINT"/>
        <result column="member_username" property="memberUsername" jdbcType="VARCHAR"/>
        <result column="refund_amount" property="refundAmount" jdbcType="DECIMAL"/>
        <result column="refund_reason" property="refundReason" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="apply_time" property="applyTime" jdbcType="TIMESTAMP"/>
        <result column="audit_time" property="auditTime" jdbcType="TIMESTAMP"/>
        <result column="auditor_id" property="auditorId" jdbcType="BIGINT"/>
        <result column="auditor_name" property="auditorName" jdbcType="VARCHAR"/>
        <result column="audit_note" property="auditNote" jdbcType="VARCHAR"/>
        <result column="third_party_refund_id" property="thirdPartyRefundId" jdbcType="VARCHAR"/>
        <result column="refund_time" property="refundTime" jdbcType="TIMESTAMP"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, refund_sn, order_id, order_sn, payment_record_id, member_id, member_username,
        refund_amount, refund_reason, status, apply_time, audit_time, auditor_id, auditor_name,
        audit_note, third_party_refund_id, refund_time, create_time, update_time
    </sql>

    <!-- 插入退款申请 -->
    <insert id="insert" parameterType="com.macro.mall.common.domain.refund.RefundRequest" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refund_request (
            refund_sn, order_id, order_sn, payment_record_id, member_id, member_username,
            refund_amount, refund_reason, status, apply_time, create_time, update_time
        ) VALUES (
            #{refundSn}, #{orderId}, #{orderSn}, #{paymentRecordId}, #{memberId}, #{memberUsername},
            #{refundAmount}, #{refundReason}, #{status}, #{applyTime}, #{createTime}, #{updateTime}
        )
    </insert>

    <!-- 根据ID查询 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_request
        WHERE id = #{id}
    </select>

    <!-- 根据退款单号查询 -->
    <select id="selectByRefundSn" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_request
        WHERE refund_sn = #{refundSn}
    </select>

    <!-- 根据订单ID查询退款申请列表 -->
    <select id="selectByOrderId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_request
        WHERE order_id = #{orderId}
        ORDER BY create_time DESC
    </select>

    <!-- 根据会员ID查询退款申请列表 -->
    <select id="selectByMemberId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_request
        <where>
            member_id = #{memberId}
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
        <if test="offset != null and limit != null">
            LIMIT #{limit} OFFSET #{offset}
        </if>
    </select>

    <!-- 更新退款申请 -->
    <update id="updateById" parameterType="com.macro.mall.common.domain.refund.RefundRequest">
        UPDATE refund_request
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditorId != null">auditor_id = #{auditorId},</if>
            <if test="auditorName != null">auditor_name = #{auditorName},</if>
            <if test="auditNote != null">audit_note = #{auditNote},</if>
            <if test="thirdPartyRefundId != null">third_party_refund_id = #{thirdPartyRefundId},</if>
            <if test="refundTime != null">refund_time = #{refundTime},</if>
            update_time = #{updateTime}
        </set>
        WHERE id = #{id}
    </update>

    <!-- 更新退款状态 -->
    <update id="updateStatus">
        UPDATE refund_request
        <set>
            status = #{status},
            <if test="thirdPartyRefundId != null">third_party_refund_id = #{thirdPartyRefundId},</if>
            <if test="failureReason != null">audit_note = #{failureReason},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 统计会员退款申请数量 -->
    <select id="countByMemberId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM refund_request
        <where>
            member_id = #{memberId}
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

</mapper>
