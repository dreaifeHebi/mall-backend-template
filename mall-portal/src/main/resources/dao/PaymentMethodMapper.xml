<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.macro.mall.portal.dao.PaymentMethodMapper">
  
  <!-- 结果映射 -->
  <resultMap id="BaseResultMap" type="com.macro.mall.portal.domain.payment.PaymentMethod">
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="method_code" jdbcType="VARCHAR" property="methodCode" />
    <result column="method_name" jdbcType="VARCHAR" property="methodName" />
    <result column="channel" jdbcType="VARCHAR" property="channel" />
    <result column="type" jdbcType="VARCHAR" property="type" />
    <result column="icon_url" jdbcType="VARCHAR" property="iconUrl" />
    <result column="status" jdbcType="INTEGER" property="status" />
    <result column="min_amount" jdbcType="DECIMAL" property="minAmount" />
    <result column="max_amount" jdbcType="DECIMAL" property="maxAmount" />
    <result column="fee_rate" jdbcType="DECIMAL" property="feeRate" />
    <result column="fixed_fee" jdbcType="DECIMAL" property="fixedFee" />
    <result column="sort" jdbcType="INTEGER" property="sort" />
    <result column="supported_currency" jdbcType="VARCHAR" property="supportedCurrency" />
    <result column="config" jdbcType="LONGVARCHAR" property="config" />
    <result column="description" jdbcType="VARCHAR" property="description" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
  </resultMap>

  <!-- 基础字段 -->
  <sql id="Base_Column_List">
    id, method_code, method_name, channel, type, icon_url, status, min_amount, max_amount,
    fee_rate, fixed_fee, sort, supported_currency, config, description, create_time, update_time
  </sql>

  <!-- 查询所有启用的支付方式 -->
  <select id="selectEnabledPaymentMethods" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List" />
    FROM oms_payment_method
    WHERE status = 1
    ORDER BY sort ASC, create_time DESC
  </select>

  <!-- 根据支付渠道查询支付方式 -->
  <select id="selectByChannel" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List" />
    FROM oms_payment_method
    WHERE channel = #{channel,jdbcType=VARCHAR}
      AND status = 1
    ORDER BY sort ASC
  </select>

  <!-- 根据支付类型查询支付方式列表 -->
  <select id="selectByType" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List" />
    FROM oms_payment_method
    WHERE type = #{type,jdbcType=VARCHAR}
      AND status = 1
    ORDER BY sort ASC
  </select>

  <!-- 根据主键查询 -->
  <select id="selectByPrimaryKey" parameterType="java.lang.Long" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List" />
    FROM oms_payment_method
    WHERE id = #{id,jdbcType=BIGINT}
  </select>

  <!-- 根据支付方式代码查询 -->
  <select id="selectByMethodCode" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List" />
    FROM oms_payment_method
    WHERE method_code = #{methodCode,jdbcType=VARCHAR}
  </select>

  <!-- 插入支付方式 -->
  <insert id="insert" parameterType="com.macro.mall.portal.domain.payment.PaymentMethod" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO oms_payment_method (
      method_code, method_name, channel, type, icon_url, status, min_amount, max_amount,
      fee_rate, fixed_fee, sort, supported_currency, config, description, create_time, update_time
    ) VALUES (
      #{methodCode,jdbcType=VARCHAR}, #{methodName,jdbcType=VARCHAR}, #{channel,jdbcType=VARCHAR},
      #{type,jdbcType=VARCHAR}, #{iconUrl,jdbcType=VARCHAR}, #{status,jdbcType=INTEGER},
      #{minAmount,jdbcType=DECIMAL}, #{maxAmount,jdbcType=DECIMAL}, #{feeRate,jdbcType=DECIMAL},
      #{fixedFee,jdbcType=DECIMAL}, #{sort,jdbcType=INTEGER}, #{supportedCurrency,jdbcType=VARCHAR},
      #{config,jdbcType=LONGVARCHAR}, #{description,jdbcType=VARCHAR}, NOW(), NOW()
    )
  </insert>

</mapper>
