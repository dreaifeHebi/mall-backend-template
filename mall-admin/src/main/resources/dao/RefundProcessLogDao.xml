<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.macro.mall.dao.refund.RefundProcessLogDao">
    
    <resultMap id="BaseResultMap" type="com.macro.mall.domain.refund.RefundProcessLog">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="refund_request_id" property="refundRequestId" jdbcType="BIGINT"/>
        <result column="refund_sn" property="refundSn" jdbcType="VARCHAR"/>
        <result column="operation_type" property="operationType" jdbcType="VARCHAR"/>
        <result column="operation_status" property="operationStatus" jdbcType="VARCHAR"/>
        <result column="operator_id" property="operatorId" jdbcType="BIGINT"/>
        <result column="operator_name" property="operatorName" jdbcType="VARCHAR"/>
        <result column="operation_note" property="operationNote" jdbcType="VARCHAR"/>
        <result column="request_params" property="requestParams" jdbcType="LONGVARCHAR"/>
        <result column="response_data" property="responseData" jdbcType="LONGVARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, refund_request_id, refund_sn, operation_type, operation_status, operator_id, 
        operator_name, operation_note, request_params, response_data, create_time
    </sql>

    <!-- 插入处理日志 -->
    <insert id="insert" parameterType="com.macro.mall.domain.refund.RefundProcessLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refund_process_log (
            refund_request_id, refund_sn, operation_type, operation_status, operator_id, 
            operator_name, operation_note, request_params, response_data, create_time
        ) VALUES (
            #{refundRequestId}, #{refundSn}, #{operationType}, #{operationStatus}, #{operatorId}, 
            #{operatorName}, #{operationNote}, #{requestParams}, #{responseData}, #{createTime}
        )
    </insert>

    <!-- 根据退款申请ID查询日志 -->
    <select id="selectByRefundRequestId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_process_log
        WHERE refund_request_id = #{refundRequestId}
        ORDER BY create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_process_log
        WHERE id = #{id}
    </select>

    <!-- 查询最近的处理日志 -->
    <select id="selectRecentLogs" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM refund_process_log
        <where>
            <if test="refundRequestId != null">
                refund_request_id = #{refundRequestId}
            </if>
            <if test="operationType != null and operationType != ''">
                AND operation_type = #{operationType}
            </if>
            <if test="operationStatus != null and operationStatus != ''">
                AND operation_status = #{operationStatus}
            </if>
        </where>
        ORDER BY create_time DESC
        <if test="limit != null">
            LIMIT #{limit}
        </if>
    </select>

</mapper>